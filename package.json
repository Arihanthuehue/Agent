{
  "name": "my-own-vapi",
  "version": "1.0.0",
  "description": "Custom Outbound AI Voice Calling Agent",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:server": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:frontend": "npm run dev --prefix frontend",
    "build": "tsc && npm install --prefix frontend && npm run build --prefix frontend",
    "start": "node dist/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-transcribe-streaming": "^3.500.0",
    "@google/genai": "^2.10.0",
    "@supabase/supabase-js": "^2.39.8",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "twilio": "^5.0.4",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "@types/ws": "^8.5.10",
    "concurrently": "^9.2.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
