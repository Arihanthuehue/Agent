# Server Configuration
PORT=3000
# Publicly accessible URL (e.g. Ngrok URL: https://your-subdomain.ngrok-free.app)
# Required for Twilio webhook endpoints. Do NOT include trailing slash.
PUBLIC_URL=

# Twilio Credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Speech-to-Text Provider: Choose 'aws' or 'deepgram'
STT_PROVIDER=aws

# AWS Credentials (for AWS Transcribe Streaming)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Deepgram API Credentials (only required if STT_PROVIDER=deepgram)
DEEPGRAM_API_KEY=

# Google Gemini API Key
GEMINI_API_KEY=

# ElevenLabs API Credentials
ELEVENLABS_API_KEY=
# Default Voice ID (e.g., 21m00Tcm4TlvDq8ikWAM - Rachel, or generic standard voice)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Supabase Credentials
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AWS Transcribe Multilingual Candidates (Broad List, one dialect per language)
CANDIDATE_LANGUAGES=en-US,hi-IN,es-US,fr-FR,ar-SA,ta-IN,te-IN,bn-IN,pt-BR,de-DE,zh-CN,ja-JP
